<component name="MainLoaderTask" extends="Task">
    <interface>
        <field id="category_id" type="string" />
        <field id="category_title" type="string" />
        <field id="action" type="string" />
        <field id="ctype" type="string" />
        <field id="cacheKey" type="string" />
        <!-- forceFresh: ignora o cache de disco e baixa SEMPRE da rede (revalidacao). -->
        <field id="forceFresh" type="bool" value="false" />
        <!-- servedFromDisk: true se a resposta veio do cache de disco (-> vale revalidar). -->
        <field id="servedFromDisk" type="bool" value="false" />
        <field id="content" type="node" />
    </interface>

    <script type="text/brightscript" uri="MainLoaderTask.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/nodeUtils.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/generalUtils.brs" />
    <script type="text/brightscript" uri="pkg:/source/utils/urlUtils.brs" />

</component>
