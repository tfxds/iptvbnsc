<?xml version="1.0" encoding="UTF-8"?>
<component name="TimeGridView" extends="BaseGroup" initialFocus="channelList">
    <interface>
	    <field id="content" type="node" alias="channelList.content" />
		<field id="category" type="node" alias="categoryList.content" />
		<field id="categorySelected" type="intarray" alwaysnotify="true" alias="categoryList.itemSelected" />
		<field id="categoryFocused" type="integer" alias="categoryList.itemFocused" alwaysNotify="true"/>
		<field id="nowTime" type="integer" />
        <field id="rowItemSelected" type="array" alwaysNotify="true" onChange="viewPrograma" />
		<field id="channelSelected" type="intarray" alwaysnotify="true" alias="channelList.itemSelected" />
		<field id="showInfo" type="boolean" alwaysNotify="true"/>
		<field id="showAdult" type="boolean" alwaysNotify="true"/>
        <function name="expandMenu" />
        <function name="collapseMenu" />
        <function name="applyCatchupMode" />
        <function name="applyMultiMode" />
    </interface>
    <script type="text/brightscript" uri="TimeGridView.brs" />
    <script type="text/brightscript" uri="pkg:/source/assets.brs" />
    <children>
        <Poster id="liveBg" width="1920" height="1080" loadDisplayMode="scaleToFill" uri="pkg:/images/live/bg.png"/>
        <Rectangle id="blending" opacity="0.25" color="0x070B14FF"/>

        <!-- VIDEO AO VIVO EM TELA CHEIA, atras de tudo. A lista de canais fica POR CIMA (overlay
             translucido), igual os apps de TV ao vivo que NAO tem a mancha preta -> nunca reduz o
             video numa janelinha (a mancha era o downscale de 4K/FHD na previa pequena). -->
        <Poster id="stbSignal" width="1920" height="1080" translation="[0,0]" uri="pkg:/images/no_signal.png" visible="false"/>
        <Video id="Video" translation="[0,0]" width="1920" height="1080" enableUI="false" enableTrickPlay="false" visible="false"/>
        <!-- Escurece o video atras dos paineis pra lista ficar legivel (some em tela cheia). -->
        <Rectangle id="browseDim" width="1010" height="1080" translation="[0,0]" color="0x070B14FF" opacity="0.55" visible="false"/>
        <!-- COLUNA DIREITA (info/sinopse): abaixo da previa, x=1030 y=600. NAO sobrepoe a lista. -->
        <Group id="group" translation="[1030,528]">
           <Poster id="infoPanelBg" width="840" height="528" loadDisplayMode="scaleToFill" uri="pkg:/images/live/info_panel.png"/>
		   <!-- LOGO REMOVIDA: mostrava a logo do revendedor (getGlobalLogoMenu) e atrapalhava.
		        O texto da info (title/info/description) agora ocupa toda a largura do painel. -->
           <Label id="title" width="784" translation="[28,28]" color="0xFFFFFFFF" maxLines="1" >
               <Font role="font" size="34" uri="pkg:/fonts/Montserrat-Bold.ttf" />
           </Label>
           <Label id="infoTimer" translation="[28,74]" color="0x3b78ffFF"  >
               <Font role="font" size="22" uri="pkg:/fonts/Montserrat-SemiBold.ttf" />
           </Label>
           <Rectangle id = "progressBarBack" width="200" height = "8" color = "0x2A3550FF" translation="[28,108]" visible="false">
             <Rectangle
               id = "progressBar"
               color = "0x3b78ffFF"
               width = "0"
               height = "8"
               inheritParentOpacity = "false"
             />
           </Rectangle>
           <Label id="info" width="784" translation="[28,118]" color="0xE8EDF7FF" maxLines="1">
               <Font role="font" size="24" uri="pkg:/fonts/Montserrat-SemiBold.ttf" />
           </Label>
           <Label id="description" width="784" height="290" translation="[28,170]" wrap="true" maxLines="9" color="0x9AA6BEFF">
               <Font role="font" size="22" uri="pkg:/fonts/Montserrat-Medium.ttf" />
           </Label>
        </Group>
        <!-- Container transparente em coords absolutas (translation [0,0]). NUNCA opacity=0 aqui. -->
        <Rectangle id = "GroupGuia" color = "0x0A0F1C00" opacity = "1" translation = "[0, 0]" visible="false">
            <!-- COLUNA ESQUERDA: categorias -->
	        <Poster id="catPanelBg" width="362" height="1032" translation="[24,24]" loadDisplayMode="scaleToFill" uri="pkg:/images/live/cat_panel_tall.png"/>
			<Label id="tituloCat" translation="[44,32]" color="0x3b78ffFF">
	            <Font role="font" size="24" uri="pkg:/fonts/Montserrat-Bold.ttf" />
	        </Label>
	        <MarkupList id="categoryList" itemComponentName="LiveCategoryItem" itemSize="[338, 56]" itemSpacing="[0, 9]" translation="[34,80]" numRows="15" drawFocusFeedback="false" vertFocusAnimationStyle="floatingfocus" wrapDividerBitmapUri="" wrapDividerHeight="0" />
            <!-- COLUNA DO MEIO: lista de canais compacta -->
	        <Poster id="chanPanelBg" width="610" height="1032" translation="[400,24]" loadDisplayMode="scaleToFill" uri="pkg:/images/live/chan_panel.png"/>
            <MarkupList
                id="channelList"
                itemComponentName = "TimeGridChannelItem"
                numColumns = "1"
                numRows = "13"
                itemSize = "[600, 68]"
                itemSpacing = "[0, 10]"
                translation = "[405, 34]"
                drawFocusFeedback = "false"
                wrapDividerBitmapUri = ""
                wrapDividerHeight = "0"
                vertFocusAnimationStyle="floatingFocus"
                visible="false"/>
	        <BusySpinner id="spinner" translation = "[680, 480]" clockwise="true" spinInterval="0.8" uri="pkg:/images/loader.png" visible="false"/>
        </Rectangle>

       <!-- COLUNA DIREITA: previa grande 16:9 (x=1030 y=110 840x472) -->
       <Poster id="previewFrame" width="852" height="484" translation="[1024,24]" loadDisplayMode="scaleToFill" uri="pkg:/images/live/preview_frame_big.png" visible="false"/>

       <!-- Logo do canal em foco preenchendo a previa enquanto navega (some ao dar play). -->
       <Poster id="previewLogo" width="300" height="300" translation="[1300,116]" loadDisplayMode="scaleToFit" loadWidth="300" loadHeight="300" failedBitmapUri="pkg:/images/channel.png" visible="false"/>

       <Poster id="aoVivoBadge" width="148" height="40" translation="[1054,54]" loadDisplayMode="scaleToFill" uri="pkg:/images/live/ao_vivo.png" visible="false"/>

       <Rectangle
	       id="RectLoading"
		   color = "0x000000FF"
		   opacity = "0.9"
		   height = "50"
		   width="840"
		   translation = "[1030,241]"
		   visible="false"/>

       <Label
	       id="videoLoading"
		   horizAlign = "center"
		   vertAlign = "center"
		   width="840"
		   translation="[1030,241]"
		   font="font:SmallBoldSystemFont"
		   visible="false"/>

       <Rectangle
			id = "InfoBar"
			height = "250"
			color = "0x080C18FF"
			opacity = "0.92">
            <Rectangle height = "250" width="300" color = "0x3b78ffFF" opacity = "0.22"/>
            <Label id="TitleInfo" width = "250" horizAlign = "center" vertAlign = "center" translation="[20,25]" color = "0xFFFFFFFF" >
                <Font role="font" size="48" uri="pkg:/fonts/Montserrat-Bold.ttf" />
            </Label>
            <Label id="TitleProgram" translation="[340,25]" color = "0xFFFFFFFF" >
                <Font role="font" size="44" uri="pkg:/fonts/Montserrat-Bold.ttf" />
            </Label>
            <Label id="TimerInfo" color = "0x3b78ffFF" >
                <Font role="font" size="38" uri="pkg:/fonts/Montserrat-SemiBold.ttf" />
            </Label>
			<Poster id="posterInfo" width="190" height="150" loadWidth = "190" loadHeight = "150" loadDisplayMode="limitSize" translation = "[50,80]" failedBitmapUri="pkg:/images/channel.png"/>
            <Label id="TimerProgram" horizAlign = "center" vertAlign = "center" translation="[340,90]" color = "0x9AA6BEFF"  >
                <Font role="font" size="27" uri="pkg:/fonts/Montserrat-SemiBold.ttf" />
            </Label>
            <Rectangle id = "progressBarBackInfo" width="200" height = "8" color = "0x2A3550FF" translation="[340,125]" visible="false">
              <Rectangle
                id = "progressBarInfo"
                color = "0x3b78ffFF"
                width = "0"
                height = "8"
                inheritParentOpacity = "false"
              />
            </Rectangle>
            <Label id="descProgram" width="750" translation="[340,140]"  wrap="true" color = "0xC4CCDCFF">
                <Font role="font" size="28" uri="pkg:/fonts/Montserrat-Medium.ttf" />
            </Label>
       </Rectangle>

       <Animation
			id = "ShowBar"
			repeat = "false"
			duration = ".2"
			easeFunction = "linear">
			<Vector2DFieldInterpolator
				fieldToInterp = "InfoBar.translation"
				key = "[0,1]"
				keyValue = "[[0,1080],[0,830]]"/>
       </Animation>

       <Animation
			id = "HideBar"
			repeat = "false"
			duration = ".2"
			easeFunction = "linear">
			<Vector2DFieldInterpolator
				fieldToInterp = "InfoBar.translation"
				key = "[0,1]"
				keyValue = "[[0,830],[0,1080]]"/>
       </Animation>

	   <StandardMessageDialog id="optionDialog" visible="false" />

       <Label
			id = "Hint"
			height = "50"
			width = "600"
			font = "font:SmallBoldSystemFont"
			translation = "[1320,50]"/>

       <!-- Hide Info Bar Timer -->
       <Timer
		   id = "TimerBar"
		   repeat = "false"
		   duration = "5"/>
       <!-- Hide Info Hint Timer -->
       <Timer
		   id = "TimerHint"
		   repeat = "false"
		   duration = "5"/>

       <!-- Overlay de CARREGANDO (por cima de tudo): aparece ao entrar, some quando os canais chegam -->
       <Group id="loadingOverlay" visible="true">
           <Rectangle width="1920" height="1080" color="0x070B14F2" />
           <!-- texto em cima, spinner girando ABAIXO (sem sobrepor) -->
           <Label id="loadingMsg" width="1920" horizAlign="center" vertAlign="center" translation="[0,455]" color="0xFFFFFFFF">
               <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="36" />
           </Label>
           <BusySpinner id="loadingSpin" translation="[896,545]" clockwise="true" spinInterval="0.9" uri="pkg:/images/loader.png" />
       </Group>

    </children>
</component>
