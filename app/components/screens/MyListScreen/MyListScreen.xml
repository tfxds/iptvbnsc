<?xml version="1.0" encoding="UTF-8"?>
<component name="MyListScreen" extends="BaseGroup"  initialFocus="markupGrid">
    <script type="text/brightscript" uri="MyListScreen.brs" />
    <script type="text/brightscript" uri="pkg:/source/assets.brs" />
	<interface>
        <!-- Specifies the content for the Grid -->
        <field id="content" type="node" alias="markupGrid.content" />
		<field id="itemSelected" type="intarray" alwaysnotify="true" alias="markupGrid.itemSelected" /> 
		<field id="jumpToRowItem" type="intarray" alias="markupGrid.jumpToItem" />
		<field id="screenLabel" type="string" alias="contentLabel.text" />
    </interface>
    <children>
	
	    <MarkupGrid
            id = "markupGrid"
            translation="[64,72]"
            itemComponentName = "MarkupGridItem"
            numColumns = "6"
            numRows = "4"
            vertFocusAnimationStyle = "fixed"
            itemSize = "[ 280, 350 ]"
            itemSpacing = "[ 16, 34 ]"
            drawFocusFeedback = "false" />

		<!-- Titulo no rodape-direita: alinhado a DIREITA dentro da zona segura,
		     assim nao estoura a tela com nenhum tamanho de texto (ex.: "Continuar Assistindo"). -->
		<Group id = "groupSection" translation="[860, 918]">
		    <Label id="contentLabel" horizAlign="right" width="930">
                <Font role = "font" uri = "pkg:/fonts/Montserrat-Black.ttf" size = "40" />
		    </Label>
        </Group>
		
    </children>
</component>
