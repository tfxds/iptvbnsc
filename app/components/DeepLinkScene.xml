	<interface>
		<!-- Main menu close handler -->
        <field id="launchArgs" type="assocarray" />
	</interface>
    <children>
         <!-- Overhang with Roku Developers logo -->
        <Overhang
            id="overhang"
            showOptions="false"
            showClock="false"
            logoUri="pkg:/images/logo.png"
            translation="[0,60]"
			visible="false"/>
        <!-- LoadingIndicator should be visible only in case of waiting for content -->
        <Label
            id="loadingIndicator"
            text="Carregando..."
            width="1280"
            height="720"
            translation="[0, 0]"
            horizAlign="center"
            vertAlign="center"
            visible="false"
            font="font:MediumBoldSystemFont"
        />
    </children>
