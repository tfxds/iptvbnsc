      <field id="itemContent" type="node" onChange="OnContentSet"/>
    </interface>

    <script type="text/brightscript" uri="ItemFuntionlist.brs" />

    <children>
      <Group>
        <Poster 
		    id="poster"
		    width="30" 
		    height="30"
