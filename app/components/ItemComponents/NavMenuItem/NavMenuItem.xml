<?xml version="1.0" encoding="utf-8" ?>
<component name="NavMenuItem" extends="BaseGroup">
  <interface>
    <field id="itemContent" type="node" onChange="onItemContentChange" />
    <field id="width" type="float" onChange="onItemContentChange" />
    <field id="height" type="float" onChange="onItemContentChange" />
    <field id="focusPercent" type="float" onChange="onFocusChange" />
  </interface>
  <script type="text/brightscript" uri="NavMenuItem.brs" />
  <!-- Layout FIXO para itemSize [400,100] (retangular, menor que o tile de Filmes).
       Icone + texto lado a lado, centralizados horizontalmente. -->
  <children>
    <Poster id="cardBg" width="392" height="92" translation="[4,4]" uri="pkg:/images/menu/navcard.png" />
    <Poster id="icon" width="40" height="40" translation="[108,30]" />
    <Label id="caption" color="0xffffff" horizAlign="left" vertAlign="center" width="240" height="40" translation="[156,30]">
      <Font role="font" uri="pkg:/fonts/Montserrat-Bold.ttf" size="22" />
    </Label>
  </children>
</component>
